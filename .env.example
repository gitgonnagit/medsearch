# Where the pipeline writes the generated dataset (read by Next.js at build time).
MEDSEARCH_DATA_DIR=./data-cache
# Optional: public data location served by Next.js (browser assets).
MEDSEARCH_PUBLIC_DATA_DIR=./public/data
# BC PharmaCare source URLs. Override only if the government renames paths.
MEDSEARCH_PDDF_URL=https://www.health.gov.bc.ca/pharmacare/outgoing/pddf.zip
# Optional: public base path under which the site is served (GitHub Pages project repo).
NEXT_PUBLIC_BASE_PATH=
